#include <TM1637Display.h>
#include <EEPROM.h>

// --------------------
// Пины
// --------------------
const byte pulsePin  = 2;    // вход импульсов
const byte outputPin = 13;   // выход

// Кнопки
const byte btnPlus1    = 4;
const byte btnPlus10   = 5;
const byte btnPlus100  = 6;
const byte btnMinus1   = 7;
const byte btnMinus10  = 8;   // B0 / D8
const byte btnMinus100 = 9;   // B1 / D9

// TM1637
const byte dioPin = 11;      // B3 / D11
const byte clkPin = 12;      // B4 / D12
TM1637Display display(clkPin, dioPin);

// --------------------
// Параметры
// --------------------
volatile unsigned int pulseCount = 0;

unsigned int pulsesPerToggle = 100;

const unsigned int minPulsesPerToggle = 30;
const unsigned int maxPulsesPerToggle = 9999;

// --------------------
// EEPROM
// --------------------
const int eepromAddress = 0;
bool eepromDirty = false;
unsigned long lastSetpointChangeMs = 0;
const unsigned long eepromSaveDelayMs = 1000;

// --------------------
// Антидребезг кнопок
// --------------------
const unsigned long debounceMs = 30;

struct ButtonState {
  byte pin;
  bool lastReading;
  bool stableState;
  unsigned long lastChangeTime;
};

ButtonState buttons[6] = {
  {btnPlus1,    HIGH, HIGH, 0},
  {btnPlus10,   HIGH, HIGH, 0},
  {btnPlus100,  HIGH, HIGH, 0},
  {btnMinus1,   HIGH, HIGH, 0},
  {btnMinus10,  HIGH, HIGH, 0},
  {btnMinus100, HIGH, HIGH, 0}
};

void setup() {
  pinMode(pulsePin, INPUT_PULLUP);
  pinMode(outputPin, OUTPUT);
  digitalWrite(outputPin, LOW);

  pinMode(btnPlus1, INPUT_PULLUP);
  pinMode(btnPlus10, INPUT_PULLUP);
  pinMode(btnPlus100, INPUT_PULLUP);
  pinMode(btnMinus1, INPUT_PULLUP);
  pinMode(btnMinus10, INPUT_PULLUP);
  pinMode(btnMinus100, INPUT_PULLUP);

  display.setBrightness(7);

  loadSetpointFromEEPROM();
  updateDisplay();

  attachInterrupt(digitalPinToInterrupt(pulsePin), pulseISR, FALLING);
}

void loop() {
  handlePulseToggle();
  handleButtons();
  handleEEPROMSave();
}

void handlePulseToggle() {
  unsigned int count;

  noInterrupts();
  count = pulseCount;
  interrupts();

  if (count >= pulsesPerToggle) {
    noInterrupts();
    pulseCount = 0;
    interrupts();

    digitalWrite(outputPin, !digitalRead(outputPin));
  }
}

void handleButtons() {
  checkButton(buttons[0], +1);
  checkButton(buttons[1], +10);
  checkButton(buttons[2], +100);
  checkButton(buttons[3], -1);
  checkButton(buttons[4], -10);
  checkButton(buttons[5], -100);
}

void checkButton(ButtonState &btn, int delta) {
  bool reading = digitalRead(btn.pin);

  if (reading != btn.lastReading) {
    btn.lastChangeTime = millis();
    btn.lastReading = reading;
  }

  if ((millis() - btn.lastChangeTime) > debounceMs) {
    if (reading != btn.stableState) {
      btn.stableState = reading;

      if (btn.stableState == LOW) {
        changeSetpoint(delta);
      }
    }
  }
}

void changeSetpoint(int delta) {
  int newValue = (int)pulsesPerToggle + delta;

  if (newValue < (int)minPulsesPerToggle) {
    newValue = minPulsesPerToggle;
  }
  if (newValue > (int)maxPulsesPerToggle) {
    newValue = maxPulsesPerToggle;
  }

  if ((unsigned int)newValue != pulsesPerToggle) {
    pulsesPerToggle = (unsigned int)newValue;

    noInterrupts();
    pulseCount = 0;
    interrupts();

    updateDisplay();

    eepromDirty = true;
    lastSetpointChangeMs = millis();
  }
}

void handleEEPROMSave() {
  if (eepromDirty && (millis() - lastSetpointChangeMs >= eepromSaveDelayMs)) {
    EEPROM.put(eepromAddress, pulsesPerToggle);
    eepromDirty = false;
  }
}

void loadSetpointFromEEPROM() {
  unsigned int storedValue = 0;
  EEPROM.get(eepromAddress, storedValue);

  if (storedValue >= minPulsesPerToggle && storedValue <= maxPulsesPerToggle) {
    pulsesPerToggle = storedValue;
  } else {
    pulsesPerToggle = 100;
    EEPROM.put(eepromAddress, pulsesPerToggle);
  }
}

void updateDisplay() {
  display.showNumberDec(pulsesPerToggle, false);
}

void pulseISR() {
  pulseCount++;
}
